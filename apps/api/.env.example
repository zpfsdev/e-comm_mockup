# API Configuration
PORT=3001

# Choose one of the following Database Connection Strings:
# Local Database (if using the provided docker-compose)
DATABASE_URL="mysql://root:change-this-strong-password@127.0.0.1:3307/artistryx"

# Production/Cloud Database (e.g., Aiven MySQL)
# DATABASE_URL="mysql://username:secure-password@your-cloud-host.com:port/defaultdb?ssl-mode=REQUIRED"

# Security Secrets (Replace these in production!)
JWT_SECRET="super-secret-jwt-key"
REFRESH_TOKEN_SECRET="super-secret-refresh-key"
CSRF_SECRET="super-secret-csrf-key"

# CORS / Origin Configuration
FRONTEND_URL="http://localhost:3000"

# Prisma Studio (secure admin panel)
STUDIO_USER="admin"
STUDIO_PASS="change-this-to-a-strong-random-password"

