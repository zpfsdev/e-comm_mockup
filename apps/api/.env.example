# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/artistryx"

# JWT
JWT_SECRET="your-secure-random-access-secret"
JWT_EXPIRES_IN="7d"

# Refresh token uses its own secret so a leaked JWT_SECRET cannot forge refresh tokens
REFRESH_TOKEN_SECRET="your-secure-random-refresh-secret"

# CSRF — separate secret so a leaked JWT_SECRET cannot forge CSRF tokens
CSRF_SECRET="your-separate-csrf-secret"

# App
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"
