{
  "name": "artistryx",
  "version": "1.0.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "multer": ">=2.1.0",
      "serialize-javascript": ">=7.0.3",
      "ajv@^8.0.0": "8.18.0"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "test": "pnpm --recursive run test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
